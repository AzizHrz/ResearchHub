spring.application.name=demo

# Database (redacted) - replace with your values in application.properties
spring.datasource.url=jdbc:mysql://localhost:3306/publishdb
spring.datasource.username=REPLACE_DB_USERNAME
spring.datasource.password=REPLACE_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
server.port=9000

# JWT secret (redacted) - set a secure random 64+ character value
jwt.secret=REPLACE_WITH_SECURE_RANDOM_SECRET
